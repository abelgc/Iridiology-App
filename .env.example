RESEND_API_KEY=
RESEND_FROM_EMAIL=Iridiology App <noreply@yourdomain.com>
CLIENT_APP_BASE_URL=http://localhost:3000

# Set to 'true' to enable the mock payment endpoint (for testing without Stripe)
ENABLE_MOCK_PAYMENT=

# Secret code that gives 100% off on the payment screen, for the owner's own testing.
# Never commit the real value — set it in your local .env and in Vercel's env vars.
OWNER_TEST_DISCOUNT_CODE=
